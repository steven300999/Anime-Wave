# Godot 4 .gitignore

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# System/tool-specific
.DS_Store
Thumbs.db
desktop.ini

# Editor-generated files
.godot/
*.uid

# Build artifacts
builds/
